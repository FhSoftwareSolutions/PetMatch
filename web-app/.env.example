# Variáveis de ambiente do frontend web (Vite).
# Copie para `.env` e ajuste se os serviços rodarem em outro host/porta.
# Atenção: o Vite só expõe ao browser variáveis com o prefixo VITE_.

# URL base da API NestJS (backend-api).
VITE_API_BASE_URL=http://localhost:3000

# URL base do motor de recomendação (recommendation-engine).
VITE_AI_ENGINE_BASE_URL=http://localhost:8000
