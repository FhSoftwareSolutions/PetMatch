# PetMatch - Motor de Recomendação / IA
# Copie para .env e ajuste conforme necessário: cp .env.example .env

# Conexão com o MongoDB (mesmo banco usado pelo backend-api).
# Use 127.0.0.1 (não "localhost") para evitar ambiguidade IPv4/IPv6 entre
# o backend (Node) e o motor (Python).
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=petmatch

# Parâmetros padrão do feed de recomendações.
DEFAULT_RADIUS_KM=25
DEFAULT_LIMIT=30
# Teto de candidatos trazidos do recall geoespacial antes do ranking.
MAX_CANDIDATES=200

# Pesos do score final (geo x conteúdo). Não precisam somar 1: são normalizados.
WEIGHT_DISTANCE=0.4
WEIGHT_CONTENT=0.6
