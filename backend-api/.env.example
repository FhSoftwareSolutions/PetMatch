# Backend API (NestJS) — variáveis de ambiente
# Copie para .env e ajuste conforme necessário.

# Conexão com o MongoDB.
MONGO_URI=mongodb://127.0.0.1:27017/petmatch

# Porta HTTP da API.
PORT=3000

# URL do motor de recomendação (usado pelo feed).
AI_ENGINE_URL=http://127.0.0.1:8000

# Segredo do JWT (TROQUE em produção) e tempo de expiração.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
